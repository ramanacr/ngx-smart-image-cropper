{
  "name": "@ramanacr/ngx-smart-image-cropper",
  "version": "0.0.1",
  "description": "Angular 21 standalone image cropper with signal state, keyboard controls, and canvas export.",
  "license": "MIT",
  "keywords": [
    "angular",
    "image-cropper",
    "signals",
    "canvas",
    "standalone"
  ],
  "peerDependencies": {
    "@angular/common": "^21.2.0",
    "@angular/core": "^21.2.0"
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "main": "bundles/ngx-smart-image-cropper.umd.js",
  "module": "fesm2020/ngx-smart-image-cropper.mjs",
  "es2020": "fesm2020/ngx-smart-image-cropper.mjs",
  "types": "ngx-smart-image-cropper.d.ts",
  "exports": {
    ".": {
      "import": "./fesm2020/ngx-smart-image-cropper.mjs",
      "require": "./bundles/ngx-smart-image-cropper.umd.js"
    }
  }
}
